# ══════════════════════════════════════════════
# ComplianceOS Environment Configuration
# Copy this to .env and fill in your values
# ══════════════════════════════════════════════

# ── Application ──
DEBUG=true
APP_NAME=ComplianceOS
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# ── Database ──
# SQLite (development):
DATABASE_URL=sqlite+aiosqlite:///./complianceos.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/complianceos

# ── AI Engine ──
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_RETRIES=3

# ── JWT Auth ──
JWT_SECRET=CHANGE_ME_ALSO_64_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── File Uploads ──
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=25
ALLOWED_EXTENSIONS=.pdf,.docx,.doc,.txt

# ── Vector Database ──
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_PREFIX=cos

# ── CORS ──
CORS_ORIGINS=["http://localhost:8000","http://localhost:3000","http://127.0.0.1:8000"]

# ── Billing (future) ──
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
